{
    "name": "pedalboard-ts",
    "version": "0.0.1",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "bin": {
        "pb": "./bin/cli.js"
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rslib",
        "check": "biome check --write",
        "dev": "rslib --watch",
        "format": "biome format --write",
        "test": "rstest",
        "test:watch": "rstest --watch"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@rslib/core": "^0.21.5",
        "@rstest/adapter-rslib": "^0.2.2",
        "@rstest/core": "^0.9.10",
        "@types/node": "^24.12.4",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.4.3",
        "@stompbox/chorus": "^2.0.1",
        "@stompbox/compressor": "^6.0.4",
        "@stompbox/spring-reverb": "^14.0.0",
        "@stompbox/tape-delay": "^3.0.5",
        "zod": "^4.4.3"
    }
}
